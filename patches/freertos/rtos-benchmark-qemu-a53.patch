diff --git a/src/freertos_aarch64_guest/fdt.c b/src/freertos_aarch64_guest/fdt.c
new file mode 100644
index 0000000000000000000000000000000000000000..446151fa842164a8e1f6d39e8759c562cb60090c
--- /dev/null
+++ b/src/freertos_aarch64_guest/fdt.c
@@ -0,0 +1,223 @@
+#include "fdt.h"
+
+#include <stddef.h>
+#include <stdint.h>
+#include <string.h>
+
+#define FDT_MAGIC 0xd00dfeedU
+#define FDT_BEGIN_NODE 0x1U
+#define FDT_END_NODE 0x2U
+#define FDT_PROP 0x3U
+#define FDT_NOP 0x4U
+#define FDT_END 0x9U
+
+struct fdt_header {
+	uint32_t magic;
+	uint32_t totalsize;
+	uint32_t off_dt_struct;
+	uint32_t off_dt_strings;
+	uint32_t off_mem_rsvmap;
+	uint32_t version;
+	uint32_t last_comp_version;
+	uint32_t boot_cpuid_phys;
+	uint32_t size_dt_strings;
+	uint32_t size_dt_struct;
+};
+
+static const void *boot_fdt_ptr;
+
+static uint32_t fdt32_to_cpu(uint32_t value)
+{
+	return __builtin_bswap32(value);
+}
+
+static uint64_t read_be_u64(const uint32_t *cells)
+{
+	uint64_t hi = fdt32_to_cpu(cells[0]);
+	uint64_t lo = fdt32_to_cpu(cells[1]);
+	return (hi << 32) | lo;
+}
+
+static size_t align4(size_t value)
+{
+	return (value + 3U) & ~3U;
+}
+
+void freertos_set_boot_fdt(const void *fdt)
+{
+	boot_fdt_ptr = fdt;
+}
+
+const void *freertos_get_boot_fdt(void)
+{
+	return boot_fdt_ptr;
+}
+
+static bool path_has_prefix(const char *path, const char *prefix)
+{
+	size_t len = strlen(prefix);
+	return strncmp(path, prefix, len) == 0;
+}
+
+static bool extract_reg64_pair(const uint8_t *value, uint32_t len, uint64_t *base, uint64_t *size)
+{
+	if (len < 16U) {
+		return false;
+	}
+
+	const uint32_t *cells = (const uint32_t *)value;
+	*base = read_be_u64(&cells[0]);
+	*size = read_be_u64(&cells[2]);
+	return true;
+}
+
+bool freertos_fdt_probe(struct fdt_resource_info *info)
+{
+	const struct fdt_header *hdr = (const struct fdt_header *)boot_fdt_ptr;
+	const uint8_t *blob;
+	const uint8_t *struct_block;
+	const char *strings;
+	const uint8_t *p;
+	char current_path[256] = "/";
+	char alias_serial1[128] = "";
+	char stdout_path[128] = "";
+	bool in_aliases = false;
+	bool in_chosen = false;
+
+	if (hdr == NULL) {
+		return false;
+	}
+
+	if (fdt32_to_cpu(hdr->magic) != FDT_MAGIC) {
+		return false;
+	}
+
+	memset(info, 0, sizeof(*info));
+
+	blob = (const uint8_t *)hdr;
+	struct_block = blob + fdt32_to_cpu(hdr->off_dt_struct);
+	strings = (const char *)(blob + fdt32_to_cpu(hdr->off_dt_strings));
+	p = struct_block;
+
+	while (1) {
+		uint32_t token = fdt32_to_cpu(*(const uint32_t *)p);
+		p += 4;
+
+		if (token == FDT_BEGIN_NODE) {
+			const char *name = (const char *)p;
+			size_t name_len = strlen(name);
+			size_t path_len = strlen(current_path);
+
+			if (strcmp(current_path, "/") == 0) {
+				if (name_len == 0) {
+					current_path[0] = '/';
+					current_path[1] = '\0';
+				} else {
+					current_path[0] = '/';
+					memcpy(&current_path[1], name, name_len + 1);
+				}
+			} else if (name_len != 0 && path_len + 1 + name_len < sizeof(current_path)) {
+				current_path[path_len] = '/';
+				memcpy(&current_path[path_len + 1], name, name_len + 1);
+			}
+
+			in_aliases = strcmp(current_path, "/aliases") == 0;
+			in_chosen = strcmp(current_path, "/chosen") == 0;
+			p += align4(name_len + 1U);
+		} else if (token == FDT_END_NODE) {
+			char *last_slash = strrchr(current_path, '/');
+			if (last_slash == current_path) {
+				current_path[1] = '\0';
+			} else if (last_slash != NULL) {
+				*last_slash = '\0';
+			}
+			in_aliases = strcmp(current_path, "/aliases") == 0;
+			in_chosen = strcmp(current_path, "/chosen") == 0;
+		} else if (token == FDT_PROP) {
+			uint32_t len = fdt32_to_cpu(*(const uint32_t *)p);
+			p += 4;
+			uint32_t nameoff = fdt32_to_cpu(*(const uint32_t *)p);
+			p += 4;
+			const char *prop_name = strings + nameoff;
+			const uint8_t *value = p;
+
+			if (in_aliases && strcmp(prop_name, "serial1") == 0) {
+				size_t copy_len = len < sizeof(alias_serial1) - 1 ? len : sizeof(alias_serial1) - 1;
+				memcpy(alias_serial1, value, copy_len);
+				alias_serial1[copy_len] = '\0';
+			}
+
+			if (in_chosen && strcmp(prop_name, "stdout-path") == 0) {
+				size_t copy_len = len < sizeof(stdout_path) - 1 ? len : sizeof(stdout_path) - 1;
+				memcpy(stdout_path, value, copy_len);
+				stdout_path[copy_len] = '\0';
+			}
+
+			if (strcmp(prop_name, "clock-frequency") == 0 && path_has_prefix(current_path, "/uartclk")) {
+				info->uart_clock_hz = fdt32_to_cpu(*(const uint32_t *)value);
+			}
+
+			if (strcmp(prop_name, "interrupts") == 0 && strstr(current_path, "uart@") != NULL) {
+				if (len >= 8U) {
+					const uint32_t *cells = (const uint32_t *)value;
+					info->timer_irq = info->timer_irq;
+					(void)cells;
+				}
+			}
+
+			if (strcmp(prop_name, "reg") == 0) {
+				bool stdout_uses_serial1 =
+					(strlen(stdout_path) > 0 && strncmp(stdout_path, "serial1", 7) == 0);
+				if ((strlen(alias_serial1) > 0 && strcmp(current_path, alias_serial1) == 0) ||
+				    (strlen(stdout_path) > 0 && stdout_path[0] == '/' &&
+				     strcmp(current_path, stdout_path) == 0) ||
+				    (stdout_uses_serial1 && strlen(alias_serial1) > 0 &&
+				     strcmp(current_path, alias_serial1) == 0)) {
+					uint64_t base, size;
+					if (extract_reg64_pair(value, len, &base, &size)) {
+						info->uart_base = base;
+					}
+				}
+
+				if (strstr(current_path, "interrupt-controller@") != NULL) {
+					uint64_t base, size;
+					if (extract_reg64_pair(value, len, &base, &size)) {
+						info->gicd_base = base;
+						if (len >= 32U) {
+							const uint32_t *cells = (const uint32_t *)value;
+							info->gicr_base = read_be_u64(&cells[4]);
+							info->gicr_size = read_be_u64(&cells[6]);
+						}
+					}
+				}
+
+				if ((strcmp(prop_name, "reg") == 0) &&
+				    (strstr(current_path, "memory@") != NULL || strstr(current_path, "sram0") != NULL ||
+				     strstr(current_path, "memory@2020000000") != NULL)) {
+					uint64_t base, size;
+					if (extract_reg64_pair(value, len, &base, &size)) {
+						info->memory_base = base;
+						info->memory_size = size;
+					}
+				}
+			}
+
+			if (strcmp(prop_name, "interrupts") == 0 && strcmp(current_path, "/timer") == 0) {
+				if (len >= 16U) {
+					const uint32_t *cells = (const uint32_t *)value;
+					info->timer_irq = fdt32_to_cpu(cells[1]);
+				}
+			}
+
+			p += align4(len);
+		} else if (token == FDT_NOP) {
+			continue;
+		} else if (token == FDT_END) {
+			break;
+		} else {
+			return false;
+		}
+	}
+
+	return info->uart_base != 0U;
+}
