diff --git a/src/freertos_aarch64_guest/arch_util.c b/src/freertos_aarch64_guest/arch_util.c
new file mode 100644
index 0000000000000000000000000000000000000000..72dde1b48621fb8b4707c3a1352ba153705e9670
--- /dev/null
+++ b/src/freertos_aarch64_guest/arch_util.c
@@ -0,0 +1,45 @@
+#include "arch_api.h"
+
+#define NSEC_PER_SEC 1000000000ULL
+
+static inline unsigned long long read_cntvct(void)
+{
+	unsigned long long value;
+	__asm volatile("mrs %0, cntvct_el0" : "=r"(value));
+	return value;
+}
+
+static inline unsigned long long read_cntfrq(void)
+{
+	unsigned long long value;
+	__asm volatile("mrs %0, cntfrq_el0" : "=r"(value));
+	return value;
+}
+
+void arch_timing_init(void)
+{
+}
+
+void arch_timing_start(void)
+{
+}
+
+void arch_timing_stop(void)
+{
+}
+
+bench_time_t arch_timing_counter_get(void)
+{
+	return read_cntvct();
+}
+
+bench_time_t arch_timing_cycles_get(volatile bench_time_t *const start,
+				    volatile bench_time_t *const end)
+{
+	return *end - *start;
+}
+
+bench_time_t arch_timing_cycles_to_ns(bench_time_t cycles)
+{
+	return (cycles * NSEC_PER_SEC) / read_cntfrq();
+}
