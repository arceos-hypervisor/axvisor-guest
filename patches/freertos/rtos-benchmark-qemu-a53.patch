+#include <stdint.h>
+
+#ifndef FREERTOS_BENCH_PL011_BASE
+#define FREERTOS_BENCH_PL011_BASE 0x2800d000UL
+#endif
+
+#ifndef FREERTOS_BENCH_GICR_BASE
+#define FREERTOS_BENCH_GICR_BASE 0x30880000UL
+#endif
+
+#ifndef FREERTOS_BENCH_GICR_REGION_SIZE
+#define FREERTOS_BENCH_GICR_REGION_SIZE 0x00080000UL
+#endif
+
+#ifndef FREERTOS_BENCH_GICR_STRIDE
+#define FREERTOS_BENCH_GICR_STRIDE 0x00020000UL
+#endif
+
+#ifndef FREERTOS_BENCH_TIMER_IRQ_ID
+#define FREERTOS_BENCH_TIMER_IRQ_ID 27U
+#endif
+
+#ifndef FREERTOS_BENCH_UART_CLK_HZ
+#define FREERTOS_BENCH_UART_CLK_HZ 100000000UL
+#endif
+
+#define PL011_BASE            FREERTOS_BENCH_PL011_BASE
+#define PL011_DR              0x000
+#define PL011_FR              0x018
+#define PL011_IBRD            0x024
+#define PL011_FBRD            0x028
+#define PL011_LCRH            0x02c
+#define PL011_CR              0x030
+#define PL011_IMSC            0x038
+#define PL011_ICR             0x044
+#define PL011_FR_TXFF         ( 1U << 5 )
+#define PL011_CR_UARTEN       ( 1U << 0 )
+#define PL011_CR_TXE          ( 1U << 8 )
+#define PL011_CR_RXE          ( 1U << 9 )
+#define PL011_LCRH_WLEN_8     ( 3U << 5 )
+#define PL011_LCRH_FEN        ( 1U << 4 )
+
+#define GICR_BASE             FREERTOS_BENCH_GICR_BASE
+#define GICR_REGION_SIZE      FREERTOS_BENCH_GICR_REGION_SIZE
+#define GICR_STRIDE           FREERTOS_BENCH_GICR_STRIDE
+#define GICR_SGI_BASE_OFF     0x10000UL
+#define GICR_TYPER            0x0008UL
+#define GICR_TYPER_LAST_BIT   ( 1UL << 4 )
+#define GIC_DIST_IGROUPR      0x0080UL
+#define GIC_DIST_ISENABLER    0x0100UL
+#define GIC_DIST_ICENABLER    0x0180UL
+#define GIC_DIST_ICPENDR      0x0280UL
+#define GIC_DIST_IPRIORITYR   0x0400UL
+#define GIC_DIST_ICFGR        0x0c00UL
+#define GIC_DIST_IGROUPMODR   0x0d00UL
+
+#define TIMER_IRQ_ID          FREERTOS_BENCH_TIMER_IRQ_ID
+
+static uintptr_t uart_base = PL011_BASE;
+static uint64_t uart_next_tx_cycle;
+
+static uint64_t tick_cycles;
+static bench_isr_handler_t current_timer_handler;
+static uintptr_t current_gicr_base;
+static struct fdt_resource_info hw;
+
+extern void FreeRTOS_Tick_Handler( void );
+
+static inline void mmio_write32(uintptr_t addr, uint32_t value)
+{
+	*(volatile uint32_t *) addr = value;
+}
+
+static inline uint32_t mmio_read32(uintptr_t addr)
+{
+	return *(volatile uint32_t *) addr;
+}
+
+static inline uint64_t read_cntfrq(void)
+{
+	uint64_t value;
+	__asm volatile("mrs %0, cntfrq_el0" : "=r"(value));
+	return value;
+}
+
+void freertos_set_boot_fdt_ptr(const void *fdt)
+{
+	freertos_set_boot_fdt(fdt);
+}
+
+static inline uint64_t read_mpidr(void)
+{
+	uint64_t value;
+	__asm volatile("mrs %0, mpidr_el1" : "=r"(value));
+	return value;
+}
+
+static inline uint64_t read_cntvct(void)
+{
+	uint64_t value;
+	__asm volatile("mrs %0, cntvct_el0" : "=r"(value));
+	return value;
+}
+
+static inline void write_cntv_tval(uint32_t value)
+{
+	__asm volatile("msr cntv_tval_el0, %0" ::"r"((uint64_t)value));
+}
+
+static inline void write_cntv_ctl(uint32_t value)
+{
+	__asm volatile("msr cntv_ctl_el0, %0" ::"r"((uint64_t)value));
+}
+
+static inline void uart_wait_tx_slot(void)
+{
+#if defined( GUEST )
+	uint64_t now = read_cntvct();
+	uint64_t target = uart_next_tx_cycle;
+
+	if (target > now) {
+		while (read_cntvct() < target) {
+		}
+		now = target;
+	}
+
+	uint64_t cycles_per_char = (read_cntfrq() * 20ULL) / 115200ULL;
+	if (cycles_per_char == 0ULL) {
+		cycles_per_char = 1ULL;
+	}
+	uart_next_tx_cycle = now + cycles_per_char;
+#endif
+}
+
+static inline uint64_t read_icc_sre_el1(void)
+{
+	uint64_t value;
+	__asm volatile("mrs %0, S3_0_C12_C12_5" : "=r"(value));
+	return value;
+}
+
+static inline void write_icc_sre_el1(uint64_t value)
+{
+	__asm volatile("msr S3_0_C12_C12_5, %0" ::"r"(value));
+}
+
+static inline void write_icc_pmr_el1(uint64_t value)
+{
+	__asm volatile("msr S3_0_C4_C6_0, %0" ::"r"(value));
+}
+
+static inline void write_icc_igrpen1_el1(uint64_t value)
+{
+	__asm volatile("msr S3_0_C12_C12_7, %0" ::"r"(value));
+}
+
+static inline uint64_t mmio_read64(uintptr_t addr)
+{
+	return *(volatile uint64_t *) addr;
+}
+
+static uint64_t mpidr_to_affinity(uint64_t mpidr)
+{
+	uint64_t aff3 = ( mpidr >> 32 ) & 0xffU;
+	uint64_t aff2 = ( mpidr >> 16 ) & 0xffU;
+	uint64_t aff1 = ( mpidr >> 8 ) & 0xffU;
+	uint64_t aff0 = mpidr & 0xffU;
+
+	return ( aff3 << 24 ) | ( aff2 << 16 ) | ( aff1 << 8 ) | aff0;
+}
+
+static uintptr_t find_current_redistributor(void)
+{
+	uint64_t target_aff = mpidr_to_affinity(read_mpidr());
+	uintptr_t addr = GICR_BASE;
+	uintptr_t end = GICR_BASE + GICR_REGION_SIZE;
+
+	while (addr < end) {
+		uint64_t typer = mmio_read64(addr + GICR_TYPER);
+		uint64_t gicr_aff = (typer >> 32) & 0xffffffffULL;
+
+		if (gicr_aff == target_aff) {
+			return addr;
+		}
+
+		if (typer & GICR_TYPER_LAST_BIT) {
+			break;
+		}
+
+		addr += GICR_STRIDE;
+	}
+
+	return 0;
+}
+
+static void pl011_init(uint64_t uart_clk_hz)
+{
+	uint32_t baud = 115200U;
+	uint64_t bauddiv_x64;
+	uint32_t ibrd;
+	uint32_t fbrd;
+
+	mmio_write32(uart_base + PL011_CR, 0);
+	mmio_write32(uart_base + PL011_IMSC, 0);
+	mmio_write32(uart_base + PL011_ICR, 0x7ff);
+
+	if (uart_clk_hz == 0U) {
+		uart_clk_hz = FREERTOS_BENCH_UART_CLK_HZ;
+	}
+
+	bauddiv_x64 = (uart_clk_hz * 4U) / baud;
+	ibrd = (uint32_t)(bauddiv_x64 / 64U);
+	fbrd = (uint32_t)(bauddiv_x64 % 64U);
+	if (ibrd == 0U) {
+		ibrd = 1U;
+	}
+
+	mmio_write32(uart_base + PL011_IBRD, ibrd);
+	mmio_write32(uart_base + PL011_FBRD, fbrd);
+	mmio_write32(uart_base + PL011_LCRH, PL011_LCRH_WLEN_8 | PL011_LCRH_FEN);
+	mmio_write32(uart_base + PL011_CR, PL011_CR_UARTEN | PL011_CR_TXE | PL011_CR_RXE);
+	uart_next_tx_cycle = 0;
+}
+
+static void pl011_putc(char c)
+{
+#if defined( GUEST )
+	/*
+	 * On Phytium guest, reading FR/TXFF can stall even though direct writes to
+	 * DR succeed. Pace writes in software to keep output readable.
+	 */
+	uart_wait_tx_slot();
+	mmio_write32(uart_base + PL011_DR, (uint32_t)c);
+	__asm volatile("dsb sy" ::: "memory");
+#else
+	uint32_t tries = 1000000U;
+	while ((mmio_read32(uart_base + PL011_FR) & PL011_FR_TXFF) && tries-- > 0U) {
+	}
+	mmio_write32(uart_base + PL011_DR, (uint32_t) c);
+#endif
+}
+
+static void pl011_puts(const char *s)
+{
+	while (*s != '\0') {
+		if (*s == '\n') {
+			pl011_putc('\r');
+		}
+		pl011_putc(*s++);
+	}
+}
+
+void freertos_uart_puts_early(const char *s)
+{
+	while (*s != '\0') {
+		if (*s == '\n') {
+			uart_wait_tx_slot();
+			mmio_write32(uart_base + PL011_DR, (uint32_t) '\r');
+		}
+		uart_wait_tx_slot();
+		mmio_write32(uart_base + PL011_DR, (uint32_t) *s++);
+	}
+}
+
+static int uart_emit_char(char c)
+{
+	if (c == '\n') {
+		pl011_putc('\r');
+	}
+	pl011_putc(c);
+	return 1;
+}
+
+static int uart_emit_repeat(char ch, int count)
+{
+	int written = 0;
+	while (count-- > 0) {
+		written += uart_emit_char(ch);
+	}
+	return written;
+}
+
+static int uart_emit_string_len(const char *s, int len)
+{
+	int written = 0;
+	for (int i = 0; i < len; i++) {
+		written += uart_emit_char(s[i]);
+	}
+	return written;
+}
+
+static int format_unsigned(char *buf, unsigned long long value, unsigned base, bool upper)
+{
+	static const char digits_lo[] = "0123456789abcdef";
+	static const char digits_hi[] = "0123456789ABCDEF";
+	const char *digits = upper ? digits_hi : digits_lo;
+	char tmp[32];
+	int pos = 0;
+	int len = 0;
+
+	if (value == 0ULL) {
+		buf[0] = '0';
+		return 1;
+	}
+
+	while (value != 0ULL) {
+		tmp[pos++] = digits[value % base];
+		value /= base;
+	}
+
+	while (pos > 0) {
+		buf[len++] = tmp[--pos];
+	}
+
+	return len;
+}
+
+static int uart_vprintf(const char *fmt, va_list ap)
+{
+	int written = 0;
+
+	while (*fmt != '\0') {
+		if (*fmt != '%') {
+			written += uart_emit_char(*fmt++);
+			continue;
+		}
+
+		fmt++;
+
+		bool left_align = false;
+		bool zero_pad = false;
+		while (*fmt == '-' || *fmt == '0') {
+			if (*fmt == '-') {
+				left_align = true;
+			} else {
+				zero_pad = true;
+			}
+			fmt++;
+		}
+
+		int width = 0;
+		while (*fmt >= '0' && *fmt <= '9') {
+			width = (width * 10) + (*fmt - '0');
+			fmt++;
+		}
+
+		int length = 0;
+		while (*fmt == 'l') {
+			length++;
+			fmt++;
+		}
+
+		char spec = *fmt ? *fmt++ : '\0';
+		char numbuf[34];
+		const char *out = NULL;
+		int len = 0;
+		bool negative = false;
+
+		switch (spec) {
+		case '%':
+			written += uart_emit_char('%');
+			continue;
+		case 'c': {
+			numbuf[0] = (char)va_arg(ap, int);
+			out = numbuf;
+			len = 1;
+			break;
+		}
+		case 's':
+			out = va_arg(ap, const char *);
+			if (out == NULL) {
+				out = "<null>";
+			}
+			while (out[len] != '\0') {
+				len++;
+			}
+			break;
+		case 'p': {
+			uintptr_t value = (uintptr_t)va_arg(ap, void *);
+			numbuf[0] = '0';
+			numbuf[1] = 'x';
+			len = 2 + format_unsigned(&numbuf[2], (unsigned long long)value, 16U, false);
+			out = numbuf;
+			break;
+		}
+		case 'd':
+		case 'i': {
+			long long value;
+			if (length >= 2) {
+				value = va_arg(ap, long long);
+			} else if (length == 1) {
+				value = va_arg(ap, long);
+			} else {
+				value = va_arg(ap, int);
+			}
+			unsigned long long magnitude;
+			if (value < 0) {
+				negative = true;
+				magnitude = (unsigned long long)(-(value + 1)) + 1ULL;
+			} else {
+				magnitude = (unsigned long long)value;
+			}
+			len = format_unsigned(numbuf, magnitude, 10U, false);
+			out = numbuf;
+			break;
+		}
+		case 'u':
+		case 'x':
+		case 'X': {
+			unsigned long long value;
+			unsigned base = (spec == 'u') ? 10U : 16U;
+			bool upper = (spec == 'X');
+			if (length >= 2) {
+				value = va_arg(ap, unsigned long long);
+			} else if (length == 1) {
+				value = va_arg(ap, unsigned long);
+			} else {
+				value = va_arg(ap, unsigned int);
+			}
+			len = format_unsigned(numbuf, value, base, upper);
+			out = numbuf;
+			break;
+		}
+		default:
+			written += uart_emit_char('%');
+			if (spec != '\0') {
+				written += uart_emit_char(spec);
+			}
+			continue;
+		}
+
+		int content_len = len + (negative ? 1 : 0);
+		int pad = (width > content_len) ? (width - content_len) : 0;
+		char pad_char = (zero_pad && !left_align) ? '0' : ' ';
+
+		if (!left_align && pad_char == ' ') {
+			written += uart_emit_repeat(' ', pad);
+		}
+		if (negative) {
+			written += uart_emit_char('-');
+		}
+		if (!left_align && pad_char == '0') {
+			written += uart_emit_repeat('0', pad);
+		}
+		written += uart_emit_string_len(out, len);
+		if (left_align) {
+			written += uart_emit_repeat(' ', pad);
+		}
+	}
+
+	return written;
+}
+
+int freertos_uart_printf(const char *fmt, ...)
+{
+	va_list ap;
+	int len;
+
+	taskDISABLE_INTERRUPTS();
+	va_start(ap, fmt);
+	len = uart_vprintf(fmt, ap);
+	va_end(ap);
+	taskENABLE_INTERRUPTS();
+
+	return len;
+}
+
+int _write(int file, const char *ptr, int len)
+{
+	(void) file;
+	taskDISABLE_INTERRUPTS();
+	for (int i = 0; i < len; i++) {
+		if (ptr[i] == '\n') {
+			pl011_putc('\r');
+		}
+		pl011_putc(ptr[i]);
+	}
+	taskENABLE_INTERRUPTS();
+	return len;
+}
+
+static void gicv3_sre_init(void)
+{
+	uint64_t icc_sre = read_icc_sre_el1();
+	if ((icc_sre & 0x1U) == 0U) {
+		icc_sre |= 0x7U;
+		write_icc_sre_el1(icc_sre);
+	}
+
+	write_icc_pmr_el1(0xffU);
+	write_icc_igrpen1_el1(1U);
+	__asm volatile("isb");
+}
+
+static void gicv3_enable_timer_ppi(void)
+{
+	uintptr_t rdist = current_gicr_base ? current_gicr_base : find_current_redistributor();
+	uintptr_t sgi_base;
+	uint32_t irq = hw.timer_irq ? hw.timer_irq : TIMER_IRQ_ID;
+	uint32_t mask = 1U << irq;
+
+	if (rdist == 0U) {
+		return;
+	}
+
+	current_gicr_base = rdist;
+	sgi_base = rdist + GICR_SGI_BASE_OFF;
+
+	mmio_write32(sgi_base + GIC_DIST_IGROUPR, 0xffffffffU);
+	mmio_write32(sgi_base + GIC_DIST_IGROUPMODR, 0xffffffffU);
+	mmio_write32(sgi_base + GIC_DIST_ICFGR + 4, 0);
+	mmio_write32(sgi_base + GIC_DIST_ICPENDR, mask);
+	*(volatile uint8_t *)(sgi_base + GIC_DIST_IPRIORITYR + irq) =
+		(uint8_t)(portLOWEST_USABLE_INTERRUPT_PRIORITY << portPRIORITY_SHIFT);
+	mmio_write32(sgi_base + GIC_DIST_ISENABLER, mask);
+}
+
+static void freertos_tick_isr(void *arg)
+{
+	(void) arg;
+	FreeRTOS_Tick_Handler();
+}
+
+void freertos_platform_init(void)
+{
+	bool have_dtb;
+	have_dtb = freertos_fdt_probe(&hw);
+
+	if (have_dtb && hw.uart_base != 0U) {
+		uart_base = (uintptr_t)hw.uart_base;
+	}
+	if (have_dtb && hw.gicr_base != 0U) {
+		current_gicr_base = (uintptr_t)hw.gicr_base;
+	}
+
+	freertos_uart_puts_early("[freertos] platform init begin\r\n");
+	pl011_init(hw.uart_clock_hz);
+	gicv3_sre_init();
+	gicv3_enable_timer_ppi();
+	current_timer_handler = freertos_tick_isr;
+}
+
+uint32_t bench_timer_cycles_per_second(void)
+{
+	return (uint32_t) read_cntfrq();
+}
+
+uint32_t bench_timer_cycles_per_tick(void)
+{
+	return bench_timer_cycles_per_second() / configTICK_RATE_HZ;
+}
+
+bench_time_t bench_timer_cycles_get(void)
+{
+	return read_cntvct();
+}
+
+bench_time_t bench_timer_cycles_diff(bench_time_t trigger, bench_time_t sample)
+{
+	return sample - trigger;
+}
+
+bench_isr_handler_t bench_timer_isr_get(void)
+{
+	return current_timer_handler;
+}
+
+void bench_timer_isr_set(bench_isr_handler_t handler)
+{
+	current_timer_handler = handler;
+}
+
+void bench_timer_isr_restore(bench_isr_handler_t handler)
+{
+	current_timer_handler = handler;
+	write_cntv_tval(bench_timer_cycles_per_tick());
+	write_cntv_ctl(1);
+}
+
+bench_time_t bench_timer_isr_expiry_set(uint32_t usec)
+{
+	uint64_t delta = ((uint64_t) bench_timer_cycles_per_second() * usec) / 1000000ULL;
+	uint64_t now = read_cntvct();
+
+	if (delta == 0) {
+		delta = 1;
+	}
+
+	write_cntv_tval((uint32_t) delta);
+	write_cntv_ctl(1);
+	return now + delta;
+}
+
+void vConfigureTickInterrupt(void)
+{
+	tick_cycles = bench_timer_cycles_per_tick();
+	write_cntv_tval((uint32_t) tick_cycles);
+	write_cntv_ctl(1);
+}
+
+void vClearTickInterrupt(void)
+{
+	write_cntv_tval((uint32_t) tick_cycles);
+	write_cntv_ctl(1);
+	__asm volatile("dsb sy");
+	__asm volatile("isb sy");
+}
+
+void vApplicationIRQHandler(uint32_t ulICCIAR)
+{
+	uint32_t intid = ulICCIAR & 0x00ffffffU;
+
+	if (intid == (hw.timer_irq ? hw.timer_irq : TIMER_IRQ_ID) && current_timer_handler != NULL) {
+		current_timer_handler(NULL);
+	}
+}
