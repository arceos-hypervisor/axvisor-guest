diff --git a/src/freertos_aarch64_qemu/linker.ld b/src/freertos_aarch64_qemu/linker.ld
new file mode 100644
index 0000000000000000000000000000000000000000..113db9298f8d7b0ebdae7b080dbfd869b8ac96c5
--- /dev/null
+++ b/src/freertos_aarch64_qemu/linker.ld
@@ -0,0 +1,56 @@
+ENTRY(_boot)
+
+MEMORY
+{
+  ram (rwx) : ORIGIN = 0x40000000, LENGTH = 0x08000000
+}
+
+SECTIONS
+{
+  . = ORIGIN(ram);
+
+  .vectors : ALIGN(2048) {
+    KEEP(*(.vectors))
+  } > ram
+
+  .text : ALIGN(16) {
+    *(.text.boot)
+    *(.text)
+    *(.text.*)
+    *(.rodata)
+    *(.rodata.*)
+    *(.gnu.linkonce.t*)
+    *(.gnu.linkonce.r*)
+  } > ram
+
+  .data : ALIGN(16) {
+    __data_start__ = .;
+    *(.data)
+    *(.data.*)
+    __data_end__ = .;
+  } > ram
+
+  .bss (NOLOAD) : ALIGN(16) {
+    __bss_start__ = .;
+    *(.bss)
+    *(.bss.*)
+    *(COMMON)
+    __bss_end__ = .;
+  } > ram
+
+  .boot_stack (NOLOAD) : ALIGN(16) {
+    __boot_stack_bottom = .;
+    . = . + 0x8000;
+    __boot_stack_top = .;
+  } > ram
+
+  end = .;
+  _end = .;
+  __end__ = .;
+
+  /DISCARD/ : {
+    *(.comment)
+    *(.note*)
+    *(.eh_frame*)
+  }
+}
