diff --git a/src/freertos_aarch64_guest/linker.ld b/src/freertos_aarch64_guest/linker.ld
new file mode 100644
index 0000000000000000000000000000000000000000..6ba221e132896a6bb5a008f35d600ff1024b6598
--- /dev/null
+++ b/src/freertos_aarch64_guest/linker.ld
@@ -0,0 +1,56 @@
+ENTRY(_boot)
+
+MEMORY
+{
+  ram (rwx) : ORIGIN = 0x2020000000, LENGTH = 0x20000000
+}
+
+SECTIONS
+{
+  . = ORIGIN(ram);
+
+  .vectors : ALIGN(2048) {
+    KEEP(*(.vectors))
+  } > ram
+
+  .text : ALIGN(16) {
+    *(.text.boot)
+    *(.text)
+    *(.text.*)
+    *(.rodata)
+    *(.rodata.*)
+    *(.gnu.linkonce.t*)
+    *(.gnu.linkonce.r*)
+  } > ram
+
+  .data : ALIGN(16) {
+    __data_start__ = .;
+    *(.data)
+    *(.data.*)
+    __data_end__ = .;
+  } > ram
+
+  .bss (NOLOAD) : ALIGN(16) {
+    __bss_start__ = .;
+    *(.bss)
+    *(.bss.*)
+    *(COMMON)
+    __bss_end__ = .;
+  } > ram
+
+  .boot_stack (NOLOAD) : ALIGN(16) {
+    __boot_stack_bottom = .;
+    . = . + 0x8000;
+    __boot_stack_top = .;
+  } > ram
+
+  end = .;
+  _end = .;
+  __end__ = .;
+
+  /DISCARD/ : {
+    *(.comment)
+    *(.note*)
+    *(.eh_frame*)
+  }
+}
diff --git a/src/freertos_aarch64_guest/platform.c b/src/freertos_aarch64_guest/platform.c
