diff --git a/src/common/bench_utils.c b/src/common/bench_utils.c
index d8181cfd6eb891f19521643572089dbf3c9adc8a..3a208a4ed80a713fcf3b54be4b84c5e6d11e37a1 100644
--- a/src/common/bench_utils.c
