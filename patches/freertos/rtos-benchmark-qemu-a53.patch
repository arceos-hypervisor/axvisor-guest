@@ -3,7 +3,67 @@
 #include "bench_api.h"
 
 #include <assert.h>
+#include <inttypes.h>
 #include <stdint.h>
+#include <string.h>
+
+#define BENCH_MAX_REPORT_ITEMS 64
+#define BENCH_TITLE_LEN 64
+#define BENCH_SUMMARY_LEN 64
+
+struct bench_report_entry {
+	char title[BENCH_TITLE_LEN];
+	char summary[BENCH_SUMMARY_LEN];
+	uint64_t avg_ns;
+	uint64_t min_ns;
+	uint64_t max_ns;
+	int has_value;
+};
+
+static struct bench_report_entry g_report_entries[BENCH_MAX_REPORT_ITEMS];
+static uint32_t g_report_count;
+static char g_current_title[BENCH_TITLE_LEN];
+
+static void copy_text(char *dst, size_t dst_len, const char *src)
+{
+	if (dst_len == 0U) {
+		return;
+	}
+
+	if (src == NULL) {
+		dst[0] = '\0';
+		return;
+	}
+
+	size_t i;
+	for (i = 0; i + 1U < dst_len && src[i] != '\0'; i++) {
+		dst[i] = src[i];
+	}
+	dst[i] = '\0';
+}
+
+static void append_report_entry(const char *summary, uint64_t avg_ns,
+				uint64_t min_ns, uint64_t max_ns, int has_value)
+{
+	if (g_report_count >= BENCH_MAX_REPORT_ITEMS) {
+		return;
+	}
+
+	struct bench_report_entry *entry = &g_report_entries[g_report_count++];
+	copy_text(entry->title, sizeof(entry->title), g_current_title);
+	copy_text(entry->summary, sizeof(entry->summary), summary);
+	entry->avg_ns = avg_ns;
+	entry->min_ns = min_ns;
+	entry->max_ns = max_ns;
+	entry->has_value = has_value;
+}
+
+void bench_stats_begin_report(void)
+{
+	g_report_count = 0;
+	g_current_title[0] = '\0';
+	memset(g_report_entries, 0, sizeof(g_report_entries));
+}
 
 void bench_stats_reset(struct bench_stats *stats)
 {
@@ -30,20 +90,47 @@ void bench_stats_update(struct bench_stats *stats, bench_time_t value,
 
 void bench_stats_report_title(const char *title)
 {
-	PRINTF("** %s [avg, min, max] in nanoseconds **\n\r", title);
+	copy_text(g_current_title, sizeof(g_current_title), title);
 }
 
 void bench_stats_report_line(const char *summary, const struct bench_stats *stats)
 {
-	PRINTF(" %-40s: %6llu, %6llu, %6llu\n\r", summary,
-	       bench_timing_cycles_to_ns(stats->avg),
-	       bench_timing_cycles_to_ns(stats->min),
-	       bench_timing_cycles_to_ns(stats->max));
+	append_report_entry(summary,
+			    (uint64_t) bench_timing_cycles_to_ns(stats->avg),
+			    (uint64_t) bench_timing_cycles_to_ns(stats->min),
+			    (uint64_t) bench_timing_cycles_to_ns(stats->max),
+			    1);
 }
 
 void bench_stats_report_na(const char *summary)
 {
-	PRINTF(" %-40s: %6s, %6s, %6s\n\r", summary, "n/a", "n/a", "n/a");
+	append_report_entry(summary, 0, 0, 0, 0);
+}
+
+void bench_stats_flush_report(void)
+{
+	const char *current_title = NULL;
+	for (uint32_t i = 0; i < g_report_count; i++) {
+		const struct bench_report_entry *entry = &g_report_entries[i];
+		if (current_title == NULL || strcmp(current_title, entry->title) != 0) {
+			current_title = entry->title;
+			PRINTF("** %s [avg, min, max] in nanoseconds **\r\n", current_title);
+		}
+
+		if (entry->has_value) {
+			PRINTF(" %-40s: %6" PRIu64 ", %6" PRIu64 ", %6" PRIu64 "\r\n",
+			       entry->summary,
+			       entry->avg_ns,
+			       entry->min_ns,
+			       entry->max_ns);
+		} else {
+			PRINTF(" %-40s: %6s, %6s, %6s\r\n",
+			       entry->summary,
+			       "n/a",
+			       "n/a",
+			       "n/a");
+		}
+	}
 }
 
 __weak void bench_collect_resources(void)
