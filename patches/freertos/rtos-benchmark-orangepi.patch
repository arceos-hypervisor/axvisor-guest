diff --git a/src/freertos_aarch64_orangepi/rk3588_aarch64.ld b/src/freertos_aarch64_orangepi/rk3588_aarch64.ld
new file mode 100644
index 0000000000000000000000000000000000000000..3582beaa9413b04afb00ff5d430b00d040bec8e7
--- /dev/null
+++ b/src/freertos_aarch64_orangepi/rk3588_aarch64.ld
@@ -0,0 +1,53 @@
+/*
+ * Linker script for FreeRTOS benchmark on RK3588 (AArch64 bare metal AMP).
+ *
+ * Memory layout for Orange Pi 5:
+ * - The binary is loaded at 0x40000000 (reserved RAM region)
+ * - Linux runs on other cores using the rest of DRAM
+ * - Total region: 16 MB (enough for benchmark + stacks)
+ */
+
+ENTRY(Reset_Handler)
+
+MEMORY
+{
+    RAM (rwx) : ORIGIN = 0x40000000, LENGTH = 16M
+}
+
+SECTIONS
+{
+    .text : {
+        *(.text.boot)
+        *(.text .text.*)
+        *(.rodata .rodata.*)
+    } > RAM
+
+    .data : {
+        . = ALIGN(8);
+        *(.data .data.*)
+        . = ALIGN(8);
+    } > RAM
+
+    .bss : {
+        . = ALIGN(8);
+        __bss_start = .;
+        *(.bss .bss.*)
+        *(COMMON)
+        . = ALIGN(8);
+        __bss_end = .;
+    } > RAM
+
+    /* Stack and heap */
+    .stack (NOLOAD) : {
+        . = ALIGN(16);
+        _stack_bottom = .;
+        . += 65536;         /* 64 KB main stack */
+        _stack_top = .;
+    } > RAM
+
+    /DISCARD/ : {
+        *(.ARM.attributes)
+        *(.comment)
+        *(.note.*)
+    }
+}
